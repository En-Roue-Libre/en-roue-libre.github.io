
<nav class="flex items-center justify-between flex-wrap p-6">
  <div class="flex items-center flex-shrink-0 text-white mr-6">
    <img src="/img/logo.png" class="mr-3 h-16" alt="Logo En Roue Libre"/>
    <span class="self-center text-xl font-semibold whitespace-nowrap hover:text-green-500">&#60;En Roue Libre&#62;</span>
  </div>
  <div class="block lg:hidden">
    <button onclick="ERL.toggleMenu('#nav-menu')" class="flex items-center px-3 py-2 border rounded text-slate-500 border-slate-500 hover:text-red hover:border-red">
      <svg class="fill-current h-3 w-3" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><title>Menu</title><path d="M0 3h20v2H0V3zm0 6h20v2H0V9zm0 6h20v2H0v-2z"/></svg>
    </button>
  </div>
  <div id="nav-menu" class="w-full block flex-grow lg:flex lg:items-center lg:w-auto hidden lg:visible">
    <div class="text-sm lg:flex-grow">
        {% set navigation = collections.all | eleventyNavigation %}
        <ul class="flex flex-col text-center mt-4 md:flex-row md:space-x-8 md:mt-0 md:text-sm md:font-medium">
            {%- for item in navigation %}
                <li>
                    <a href="{{ item.url | url }}" class="{{ 'lg:border-b-2 border-red-600 text-red-600 font-extrabold' if item.url === page.url }} block py-2 pr-4 pl-3 text-lg text-slate-200 hover:text-red-600" {{ 'aria-current=page' if item.url === page.url }}>{{ item.title }}</a>
                </li>
            {%- endfor %}
        </ul>
    </div>
  </div>
</nav>
<script>
    window.ERL = {
        toggleMenu: function (menuSelector) {
            const menu = document.querySelector(menuSelector)
            if(menu.classList.contains("hidden")) {
                menu.classList.remove("hidden");
            } else {
                menu.classList.add("hidden");
            }
        }
    }
</script>
